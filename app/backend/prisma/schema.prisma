generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  nom            String
  prenom         String
  email          String   @unique
  password       String
  pays           String
  fonction       String
  secteurActivite String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

model Actualite {
  id          String   @id @default(cuid())
  titre       String
  contenu     String
  image       String?
  auteur      String
  date        DateTime @default(now())
  categorie   String   @default("actualite")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("actualites")
}

model Evenement {
  id          String   @id @default(cuid())
  titre       String
  description String
  date        DateTime
  lieu        String
  image       String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("evenements")
}