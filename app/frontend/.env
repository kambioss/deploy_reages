# ─────────────────────────────────────────────────────────────────────────────
# REAAGESS Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Backend Express API URL (server-side only — used by Next.js proxy routes)
API_URL=http://localhost:3001

# Next.js app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Secret (same as backend)
JWT_SECRET=reaages-jwt-super-secret-2024-changez-moi

# Node environment
NODE_ENV=development

# Local SQLite (used by some local API routes as fallback)
DATABASE_URL="file:./dev.db"
