generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  nom             String
  prenom          String
  email           String        @unique
  password        String
  pays            String
  fonction        String
  secteurActivite String
  role            String        @default("student")
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  enrollments     Enrollment[]

  @@map("users")
}

model Cours {
  id          String       @id @default(cuid())
  titre       String
  description String
  contenu     String
  image       String?
  instructeur String
  duree       String
  niveau      String       @default("debutant")
  categorie   String
  published   Boolean      @default(false)
  prix        Float        @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]

  @@map("cours")
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  coursId   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cours     Cours    @relation(fields: [coursId], references: [id], onDelete: Cascade)

  @@unique([userId, coursId])
  @@map("enrollments")
}

model Actualite {
  id        String   @id @default(cuid())
  titre     String
  contenu   String
  image     String?
  auteur    String
  date      DateTime @default(now())
  categorie String   @default("actualite")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("actualites")
}

model Evenement {
  id          String   @id @default(cuid())
  titre       String
  description String
  date        DateTime
  lieu        String
  image       String?
  lien        String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("evenements")
}

model Article {
  id        String   @id @default(cuid())
  titre     String
  contenu   String
  resume    String
  image     String?
  auteur    String
  categorie String   @default("publication")
  tags      String   @default("")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("articles")
}

model Projet {
  id          String   @id @default(cuid())
  titre       String
  description String
  contenu     String
  image       String?
  statut      String   @default("en_cours")
  partenaires String   @default("")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projets")
}
